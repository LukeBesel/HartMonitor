# ─── HartMonitor backend environment ────────────────────────────────────────
# Copy to ".env" for local development. In production (Railway, Render, etc.)
# set these as environment variables in the platform dashboard instead.
#
# Everything is optional. With nothing set, the app runs fully — payments,
# email, SMS and SSO operate in DEMO mode (they simulate/log instead of doing
# the real thing) and flip to LIVE automatically the moment you add real keys.

# ─── Core ────────────────────────────────────────────────────────────────────
# NODE_ENV=production            # set to "production" on your host
# PORT=3001                      # the platform usually sets this for you

# Public base URL of the deployed app. Used for OAuth + Stripe redirects and to
# lock down CORS in production. Set this to your real URL once you know it.
# APP_URL=https://yourapp.up.railway.app

# Comma-separated extra browser origins allowed to call the API (rarely needed,
# since the frontend is served from the same origin as the API).
# ALLOWED_ORIGINS=https://app.yourdomain.com

# ─── Database & backups (IMPORTANT in production) ────────────────────────────
# Point the SQLite database at a PERSISTENT volume so data survives redeploys.
# On Railway/Render, mount a volume (e.g. at /data) and set:
# DATABASE_PATH=/data/mes.db
# BACKUP_DIR=/data/backups       # enables automated backups (disabled if unset)
# BACKUP_INTERVAL_HOURS=6
# BACKUP_KEEP=14

# ─── Development convenience ─────────────────────────────────────────────────
# Seeds the demo company + sample login accounts (admin@hartmonitor.demo /
# Admin123!, etc.). NEVER enable this in production — it ships known credentials.
# Set to "true" only for local development.
SEED_DEMO_DATA=true

# ─── Real payments (Stripe) ─────────────────────────────────────────────────
# Leave unset to run billing in DEMO mode (upgrades apply instantly, no charge).
# 1. Create a Stripe account at https://dashboard.stripe.com and finish the
#    "Activate payments" steps (add your bank account + verify your business).
# 2. Copy your secret key (sk_test_… while testing, sk_live_… when live).
# 3. Add a webhook endpoint in Stripe pointing at:
#       https://YOUR_DOMAIN/api/webhooks/stripe
#    subscribe it to: checkout.session.completed,
#    customer.subscription.updated, customer.subscription.deleted, invoice.paid
#    then copy its signing secret (whsec_…) below.
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# BILLING_CURRENCY=usd

# ─── Email alerts (SMTP) ─────────────────────────────────────────────────────
# Set all four to send real emails (downtime, NCRs, low stock, schedule changes).
# Any transactional email provider works (e.g. SendGrid, Postmark, Amazon SES,
# Mailgun) — use the SMTP credentials they give you.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# SMTP_FROM=alerts@yourdomain.com
# SMTP_SECURE=false

# ─── SMS alerts (Twilio) ─────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+15551234567

# ─── SSO (Google / Microsoft) ────────────────────────────────────────────────
# Set a provider's client id + secret to enable real "Continue with …" login.
# Redirect/callback URL to register with the provider:
#   https://YOUR_DOMAIN/api/auth/sso/google/callback
#   https://YOUR_DOMAIN/api/auth/sso/microsoft/callback
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# MICROSOFT_CLIENT_ID=xxx
# MICROSOFT_CLIENT_SECRET=xxx
