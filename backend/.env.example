# ─── HartMonitor backend environment ────────────────────────────────────────
# Copy to ".env" for local development. In production (Railway, etc.) set these
# as environment variables in the platform dashboard instead.

# Port the API listens on (Railway sets this automatically).
# PORT=3001

# ─── Real payments (Stripe) ─────────────────────────────────────────────────
# Leave these unset to run billing in DEMO mode (upgrades apply instantly with
# no charge). Set them to take real money that pays out to your bank account.
#
# 1. Create a Stripe account at https://dashboard.stripe.com and finish the
#    "Activate payments" steps (add your bank account + verify your business).
#    Stripe then automatically pays your balance out to that bank on a schedule.
# 2. Copy your secret key here (sk_test_… while testing, sk_live_… when live).
# 3. Add a webhook endpoint in Stripe pointing at:
#       https://YOUR_DOMAIN/api/webhooks/stripe
#    subscribe it to: checkout.session.completed,
#    customer.subscription.updated, customer.subscription.deleted, invoice.paid
#    then copy its signing secret (whsec_…) below.

# STRIPE_SECRET_KEY=<your-stripe-secret-key>
# STRIPE_WEBHOOK_SECRET=<your-webhook-signing-secret>

# Public base URL used for Stripe Checkout success/cancel redirects.
# Defaults to the request's host if unset.
# APP_URL=https://yourapp.example.com

# Billing currency (three-letter ISO code). Defaults to usd.
# BILLING_CURRENCY=usd
